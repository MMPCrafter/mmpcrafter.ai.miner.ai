{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and preferences",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "settings": {
          "type": "object",
          "properties": {
            "theme": { "type": "string", "enum": ["light", "dark", "system"] },
            "notifications": { "type": "boolean" }
          }
        },
        "customApiKey": { "type": "string" }
      },
      "required": ["displayName", "email", "createdAt"]
    },
    "Creation": {
      "title": "Generated Creation",
      "description": "A Minecraft asset generated by the AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["mod", "skin", "addon", "world"] },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isPublic": { "type": "boolean" }
      },
      "required": ["userId", "type", "name", "content", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a chat history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "/creations/{creationId}": {
      "schema": "Creation",
      "description": "Assets created by users"
    },
    "/chats/{messageId}": {
      "schema": "ChatMessage",
      "description": "Persistent chat history logs"
    }
  }
}
