rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations (Pillar 2) ---

    function isValidUser(data) {
      return (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100) &&
             (data.get('email', '') is string && data.get('email', '').size() <= 150) &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 500) &&
             (data.get('customApiKey', '') is string && data.get('customApiKey', '').size() <= 256);
    }

    function isValidCreation(data) {
      return data.get('userId', '') == request.auth.uid &&
             data.get('type', '') in ['mod', 'skin', 'addon', 'world'] &&
             data.get('name', '') is string && data.get('name', '').size() <= 100 &&
             data.get('content', '') is string && data.get('content', '').size() <= 50000;
    }

    function isValidChatMessage(data) {
      return data.get('userId', '') == request.auth.uid &&
             data.get('role', '') in ['user', 'model'] &&
             data.get('text', '') is string && data.get('text', '').size() <= 5000;
    }

    // --- Collection Routes ---

    match /test/connection {
      allow get: if isSignedIn();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if false; 
      
      allow create: if isOwner(userId) && isValidId(userId) && 
                      incoming().keys().hasAll(['displayName', 'email', 'createdAt']) &&
                      incoming().keys().size() >= 3 &&
                      isValidUser(incoming()) && 
                      incoming().createdAt == request.time;
      
      allow update: if isOwner(userId) && isValidId(userId) && 
                      isValidUser(incoming()) && (
                        // Profile Sync / Settings update
                        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin', 'settings', 'customApiKey']) &&
                         (incoming().get('lastLogin', request.time) == request.time))
                      );
    }

    match /chats/{messageId} {
      allow get: if isSignedIn() && isValidId(messageId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isOwner(incoming().userId) && isEmailVerified() && 
                      isValidChatMessage(incoming()) && 
                      incoming().keys().hasAll(['userId', 'role', 'text', 'createdAt']) &&
                      incoming().createdAt == request.time;
      
      allow delete: if isOwner(existing().userId) && isValidId(messageId);
    }

    match /creations/{creationId} {
      allow get: if isSignedIn() && isValidId(creationId) && (resource.data.isPublic == true || isOwner(resource.data.userId));
      allow list: if isSignedIn() && (resource.data.isPublic == true || isOwner(resource.data.userId));
      
      allow create: if isOwner(incoming().userId) && isEmailVerified() &&
                      isValidCreation(incoming()) && 
                      incoming().keys().hasAll(['userId', 'type', 'name', 'content', 'createdAt']) &&
                      incoming().createdAt == request.time;
      
      allow update: if isOwner(existing().userId) && isValidId(creationId) && 
                      isValidCreation(incoming()) && (
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'content', 'isPublic'])
                      );
      
      allow delete: if isOwner(existing().userId) && isValidId(creationId);
    }
  }
}
